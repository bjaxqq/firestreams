<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_selector"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:clipToOutline="true"
    android:elevation="4dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="113dp">

        <ImageView
            android:id="@+id/card_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@color/bg_card" />

        <View
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_gravity="bottom"
            android:background="@drawable/card_image_scrim" />

        <!-- Sport label shown as placeholder when no poster -->
        <TextView
            android:id="@+id/card_sport_label"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="#28FFFFFF"
            android:textSize="11sp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.2"
            android:visibility="gone" />

        <TextView
            android:id="@+id/card_live_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="6dp"
            android:layout_gravity="top|start"
            android:background="@drawable/live_pill"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="LIVE"
            android:textColor="@color/text_primary"
            android:textSize="9sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:visibility="gone" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/card_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/card_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.04"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

</LinearLayout>
