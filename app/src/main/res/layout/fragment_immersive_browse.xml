<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Full-screen background image -->
    <ImageView
        android:id="@+id/bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <!-- Full-screen dark overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000" />

    <!-- Card rows — paddingTop pushes content below info panel -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rows_recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="200dp"
        android:paddingBottom="130dp"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:focusable="false"
        android:descendantFocusability="afterDescendants" />

    <!-- Top fade: opaque at top, dissolves downward -->
    <View
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_gravity="top"
        android:background="@drawable/player_top_scrim" />

    <!-- Bottom fade -->
    <View
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_gravity="bottom"
        android:background="@drawable/card_image_scrim" />

    <!-- Info panel: transparent, floats at top, white text -->
    <LinearLayout
        android:id="@+id/info_panel"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="48dp"
        android:paddingEnd="48dp">

        <TextView
            android:id="@+id/info_live_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/live_pill"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.12"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="LIVE"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/info_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:letterSpacing="-0.015"
            android:maxLines="2"
            android:textColor="#FFFFFF"
            android:textSize="34sp" />

        <TextView
            android:id="@+id/info_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:letterSpacing="0.06"
            android:textColor="#AAAAAA"
            android:textSize="14sp" />

    </LinearLayout>

</FrameLayout>
