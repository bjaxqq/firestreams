<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:show_buffering="never" />

    <!-- Centered loading spinner + label -->
    <LinearLayout
        android:id="@+id/player_loading_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">

        <ProgressBar
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:indeterminateTint="#FFFFFF"
            style="@android:style/Widget.Material.ProgressBar" />

        <TextView
            android:id="@+id/player_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Finding stream…"
            android:textColor="#66FFFFFF"
            android:textSize="13sp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.04" />

    </LinearLayout>

    <!-- Top info bar: shown briefly on stream start, on key press -->
    <FrameLayout
        android:id="@+id/player_info_bar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="top"
        android:alpha="0"
        android:visibility="invisible">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/player_top_scrim" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="48dp"
            android:paddingEnd="48dp">

            <TextView
                android:id="@+id/player_live_pill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/live_pill"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="LIVE"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"
                android:visibility="gone" />

            <TextView
                android:id="@+id/player_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="sans-serif-light"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/player_source_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#55FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:letterSpacing="0.04" />

        </LinearLayout>
    </FrameLayout>

</FrameLayout>
