<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="260dp"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:background="@color/bg_card">

    <ImageView
        android:id="@+id/hero_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <!-- Left-to-right dark scrim for text legibility -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/hero_scrim" />

    <!-- Bottom fade into background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="bottom"
        android:background="@drawable/card_image_scrim" />

    <!-- Content overlay -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="64dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/hero_live_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/live_pill"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="LIVE"
            android:textColor="@color/text_primary"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.12"
            android:visibility="gone" />

        <TextView
            android:id="@+id/hero_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-light"
            android:maxWidth="420dp"
            android:maxLines="2"
            android:shadowColor="#99000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="6" />

        <TextView
            android:id="@+id/hero_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.06" />

        <TextView
            android:id="@+id/hero_watch_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/watch_button_bg"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:text="WATCH LIVE"
            android:textColor="#000000"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08"
            android:focusable="true"
            android:focusableInTouchMode="true" />

    </LinearLayout>

</FrameLayout>
